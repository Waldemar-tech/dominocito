# =============================================================
# Dominócito Backend — Environment Variables
# =============================================================
# Copy this file to .env and fill in your values.
# Generate secrets: npx ts-node scripts/generate-keys.ts

# ─── Server ──────────────────────────────────────────────────
PORT=3200
NODE_ENV=production

# ─── Database ─────────────────────────────────────────────────
DB_HOST=your_db_host
DB_PORT=5432
DB_NAME=your_db_name
DB_USER=your_db_user
DB_PASSWORD=your_strong_password_here

# ─── JWT — Short-lived access tokens (15 min) ────────────────
# Generate: openssl rand -hex 64
JWT_SECRET=your_super_secret_jwt_key_MINIMUM_64_HEX_CHARS
JWT_EXPIRES_IN=900               # seconds (15 min)
REFRESH_TOKEN_EXPIRES_DAYS=7    # days

# ─── AES-256-GCM Encryption ──────────────────────────────────
# Used to encrypt: dc_users.email, dc_wallet_transactions.descripcion
# Generate: openssl rand -hex 32
# ⚠️  CRITICAL: losing this key = data permanently unreadable
ENCRYPTION_KEY=                  # 32 bytes hex (64 chars)

# ─── Service Token (internal service-to-service auth) ────────
# Required for /admin/* routes alongside X-Admin-Key
# Generate: openssl rand -hex 32
SERVICE_TOKEN=                   # 32 bytes hex

# ─── Admin API key ────────────────────────────────────────────
# Required for all /admin/* endpoints (X-Admin-Key header)
# Generate: openssl rand -hex 32
ADMIN_API_KEY=your_strong_admin_api_key_here
ADMIN_LOCALHOST_ONLY=false

# ─── ECDSA Signing Keys ───────────────────────────────────────
# Auto-generated in keys/ directory on first server start.
# Back up keys/ec-private.pem to a secure vault!
# No env var needed — keys managed on disk.

# ─── Banca ────────────────────────────────────────────────────
BANCA_INICIAL=25000
BANCA_TOPE_PORCENTAJE=20

# ─── CORS ─────────────────────────────────────────────────────
# Set to your actual domain in production; never use wildcard (*)
CORS_ORIGIN=https://your-domain.com

# ─── Testing (NEVER true in production) ───────────────────────
TESTING_MODE=false
